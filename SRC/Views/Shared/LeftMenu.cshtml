
@*
    For more information on enabling MVC for empty projects, visit http://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    var user = ViewBag.CurrentUser as QuanLySanBong.Models.User;
}
<aside class="sidenav navbar navbar-vertical navbar-expand-xs border-0 border-radius-xl my-3 fixed-start ms-3   bg-gradient-dark" id="sidenav-main">
    <div class="sidenav-header">
        <i class="fas fa-times p-3 cursor-pointer text-white opacity-5 position-absolute end-0 top-0 d-none d-xl-none" aria-hidden="true" id="iconSidenav"></i>
        <a class="navbar-brand m-0" asp-controller="Home" asp-action = "" target="">
            <img src="~/assets/img/logo-ct.png" class="navbar-brand-img h-100" alt="main_logo">
            <span class="ms-1 font-weight-bold text-white">QUẢN LÝ SÂN BÓNG ĐÁ</span>
        </a>
    </div>
    <hr class="horizontal light mt-0 mb-2">
    <div class="collapse navbar-collapse  w-auto " id="sidenav-collapse-main">
        <ul class="navbar-nav">
            <li class="nav-item">
                <a class="nav-link text-white @Html.Raw(ViewBag.active == 1 ? "active bg-gradient-primary":"")" asp-controller="Home" asp-action="">
                    <div class="text-white text-center me-2 d-flex align-items-center justify-content-center">
                        <i class="material-icons opacity-10">dashboard</i>
                    </div>
                    <span class="nav-link-text ms-1">Danh sách sân bóng</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-white @Html.Raw(ViewBag.active == 2 ? "active bg-gradient-primary":"")" asp-controller="Home" asp-action="SanDaDat">
                    <div class="text-white text-center me-2 d-flex align-items-center justify-content-center">
                        <i class="material-icons opacity-10">table_view</i>
                    </div>
                    <span class="nav-link-text ms-1">Sân đã đặt</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-white @Html.Raw(ViewBag.active == 3 ? "active bg-gradient-primary":"")" asp-controller="Home" asp-action="HoaDon" >
                    <div class="text-white text-center me-2 d-flex align-items-center justify-content-center">
                        <i class="material-icons opacity-10">receipt_long</i>
                    </div>
                    <span class="nav-link-text ms-1">Hóa đơn</span>
                </a>
            </li>

            @if (user != null && (user?.LoaiUser ?? false))
            {
                <li class="nav-item">
                    <a class="nav-link text-white @Html.Raw(ViewBag.active == 5 ? "active bg-gradient-primary" : "")" asp-controller="DanhMuc" asp-action="Index">
                        <div class="text-white text-center me-2 d-flex align-items-center justify-content-center">
                            <i class="material-icons opacity-10">menu</i>
                        </div>
                        <span class="nav-link-text ms-1">Danh mục</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white @Html.Raw(ViewBag.active == 4 ? "active bg-gradient-primary":"")" asp-controller="BaoCao" asp-action="Index">
                        <div class="text-white text-center me-2 d-flex align-items-center justify-content-center">
                            <i class="material-icons opacity-10">analytics</i>
                        </div>
                        <span class="nav-link-text ms-1">Báo cáo</span>
                    </a>
                </li>

               
            }
            <li class="nav-item mt-3">
                <h6 class="ps-4 ms-2 text-uppercase text-xs text-white font-weight-bolder opacity-8">Account pages</h6>
            </li>          

            
            <li class="nav-item">
                <a class="nav-link text-white " asp-controller="Access" asp-action="Login">
                    <div class="text-white text-center me-2 d-flex align-items-center justify-content-center">
                        <i class="material-icons opacity-10">@(user != null && (user?.UserId ?? 0) > 0 ? "logout" : "login")</i>
                    </div>
                    <span class="nav-link-text ms-1">Đăng @(user != null && (user?.UserId ?? 0) > 0 ? "Xuất" : "Nhập")</span>
                </a>
            </li>
            
        </ul>
    </div>
</aside>