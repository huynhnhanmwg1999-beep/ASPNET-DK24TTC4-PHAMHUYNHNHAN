@model IEnumerable<QuanLySanBong.Controllers.PlayGroungListItemVM>
@{
    Layout = "~/Views/Shared/LayoutSanbong.cshtml";
    ViewData["Title"] = "Danh mục sân bóng";
}

@if (TempData["Ok"] != null)
{
    <div class="alert alert-success">@TempData["Ok"]</div>
}
@if (TempData["Err"] != null)
{
    <div class="alert alert-danger">@TempData["Err"]</div>
}

<div class="container-fluid py-4">
    <div class="row">
        <div class="col-12">
            <div class="card my-4">
                <div class="card-header p-0 position-relative mt-n4 mx-3 z-index-2">
                    <div class="bg-gradient-primary shadow-primary border-radius-lg pt-2 pe-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <h6 class="text-white text-capitalize ps-3">@ViewData["Title"]</h6>
                            <a asp-action="Create" class="btn btn-success"><i class="fa fa-plus me-1"></i> Thêm sân</a>
                        </div>
                    </div>
                </div>
                <div class="card-body px-0 pb-2">
                    <div class="table-responsive p-0">
                        <table class="table align-items-center mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width:50px">ID</th>
                                    <th>Tên sân bóng</th>
                                    <th style="width:100px">Số điện thoại</th>
                                    <th style="max-width:200px">Địa chỉ</th>
                                    <th style="max-width:200px">Link hình</th>
                                    <th style="max-width:200px">Mô tả</th>
                                    <th style="width:100px"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in Model)
                                {
                                    <tr>
                                        <td>@c.Id</td>
                                        <td>@c.Name</td>
                                        <td>@c.Phone</td>
                                        <td>@c.Address</td>
                                        <td>@c.Image</td>
                                        <td style="white-space: normal; word-break: normal;">@c.Description</td>
                                        <td class="text-end">
                                            <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-sm btn-warning">Sửa</a>
                                            <a asp-action="Delete" asp-route-id="@c.Id" class="btn btn-sm btn-danger">Xoá</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>   