@model QuanLySanBong.Models.PlayGround
@{
    Layout = "~/Views/Shared/LayoutSanbong.cshtml";
    ViewData["Title"] = "Sửa sân bóng";
}

<div class="row">
    <div class="col-lg-4 col-md-8 col-12 mx-auto">
        <div class="card z-index-0 fadeIn3 fadeInBottom">
            <div class="card-header p-0 position-relative mt-n4 mx-3 z-index-2">
                <div class="bg-gradient-primary shadow-primary border-radius-lg py-3 pe-1">
                    <h4 class="text-white font-weight-bolder text-center mb-0">@ViewData["Title"]</h4>
                </div>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post" class="mt-3">
                    <div class="mb-3">
                        <div class="input-group input-group-outline mb-3">
                            <input asp-for="PlayGroundName" type="text" class="form-control" placeholder="Tên sân bóng">
                            <span asp-validation-for="PlayGroundName" class="text-danger"></span>
                        </div>

                        <div class="input-group input-group-outline mb-3">
                            <input asp-for="PhoneNumber" type="text" class="form-control" placeholder="Số điện thoại">
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>

                        <div class="input-group input-group-outline mb-3">
                            <input asp-for="Address" type="text" class="form-control" placeholder="Địa chỉ">
                            <span asp-validation-for="Address" class="text-danger"></span>
                        </div>

                        <div class="input-group input-group-outline mb-3">
                            <input asp-for="Image" type="text" class="form-control" placeholder="Link hình">
                            <span asp-validation-for="Image" class="text-danger"></span>
                        </div>

                        <div class="input-group input-group-outline mb-3">
                            <input asp-for="Description" type="text" class="form-control" placeholder="Mô tả">
                        </div>

                    </div>
                    <button class="btn btn-success">Lưu</button>
                    <a asp-action="Index" class="btn btn-warning ms-1">Hủy</a>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}